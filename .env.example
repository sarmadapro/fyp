# ============================================================
# VoiceRAG SaaS Platform — Configuration Template
# Copy this to .env and fill in your values.
# ============================================================

# ── LLM (priority: Groq → Ollama) ──────────────────────────
# If GROQ_API_KEY is set and non-empty, Groq is used automatically.
# Otherwise falls back to Ollama (free, local).
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── Database ────────────────────────────────────────────────
# SQLite (default, zero config):
# DATABASE_URL=sqlite:///./data/voicerag.db
#
# PostgreSQL (production):
DATABASE_URL=postgresql://voicerag:password@localhost:5432/voicerag

# ── Auth & Security ─────────────────────────────────────────
JWT_SECRET_KEY=your-very-long-random-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (optional — needed for email verification & password reset) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@voicerag.ai
FRONTEND_URL=http://localhost:5173

# ── Backend ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── STT Service (Faster-Whisper) ────────────────────────────
STT_SERVICE_URL=http://localhost:8001
STT_MODEL_SIZE=small
STT_DEVICE=cpu          # or "cuda" for GPU
STT_COMPUTE_TYPE=int8   # or "float16" for GPU

# ── TTS Service (Kokoro + Edge-TTS) ─────────────────────────
TTS_SERVICE_URL=http://localhost:8002
TTS_VOICE=af_sky
TTS_LANG_CODE=a         # 'a' = American English

# ── RAG Pipeline ────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=8
